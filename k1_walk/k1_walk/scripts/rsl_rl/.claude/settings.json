{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(_labpython *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git reset --hard HEAD~1)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(nvidia-smi *)",
      "Bash(tensorboard *)",
      "Edit(./k1_walk_env_cfg.py)",
      "Edit(./fast_sac_cfg.py)",
      "Bash(bash train_for_llm.sh)",
      "Bash(source ~/.bash_functions*)"
    ],
    "ask": [],
    "deny": [
      "Bash(git reset *)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git config *)",
      "Bash(git remote *)",
      "Bash(rm *)",
      "Bash(pip install *)",
      "Bash(python *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./deny-check.sh"
          }
        ]
      }
    ]
  }
}